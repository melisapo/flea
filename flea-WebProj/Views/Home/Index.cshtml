@model flea_WebProj.Models.ViewModels.Product.SearchPostViewModel

@{
    ViewData["Title"] = "Inicio";
    var isAuth = ViewBag.IsAuthenticated as bool? ?? false;
}

<main class="max-w-7xl mx-auto px-6">
    <!-- Hero Banner -->
    <div class="bg-[#25231e] mt-3 rounded-3xl p-16 mb-8 relative overflow-hidden">
        <div class="absolute inset-0 opacity-50" style="background-image: radial-gradient(#98cf54 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>
        <div class="relative z-10">
            <div class="flex flex-col md:flex-row items-center justify-between gap-8">
                <div class="flex-1">
                    <h1 class="text-5xl md:text-6xl font-extrabold text-secondary mb-4 tracking-tight">
                        FLEA<span class="text-primary">MARKET</span>
                    </h1>
                    <p class="text-xl text-muted/70 font-medium max-w-xl">
                        Compra y vende productos de segunda mano en tu comunidad
                    </p>
                </div>
                    <div>
                        <a asp-controller="Posts" asp-action="Create" 
                           class="inline-flex items-center gap-3 bg-[#98cf54] hover:bg-[#88bf44] text-white px-8 py-4 rounded-2xl font-bold text-lg shadow-xl shadow-[#98cf54]/20 transition-all hover:scale-105">
                            <span class="material-symbols-outlined">add_circle</span>
                            Publicar Producto
                        </a>
                    </div>
            </div>
        </div>
    </div>

    <div class="flex flex-col xl:flex-row xl:items-start items-center gap-10">
        <!-- Sidebar: Filters (25%) -->
        <aside class="xl:w-1/4 xl:sticky top-24 h-fit">
            <div>
                
                <form asp-action="Index" method="get" id="filterForm">
                    <!-- Search -->
                    <div class="mb-4">
                        <h4 class="font-bold text-sm mb-4">Búsqueda</h4>
                        <div class="relative">
                            <input type="text" 
                                   name="searchTerm" 
                                   value="@Model.SearchTerm"
                                   class="w-full px-4 py-3 text-sm bg-white border-none ring-1 ring-gray-200 rounded-xl focus:ring-2 focus:ring-[#98cf54] outline-none" 
                                   placeholder="Buscar productos..."/>
                            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">search</span>
                        </div>
                    </div>

                    <div class="flex gap-2 items-center justify-around m-2">                    <!-- Categories -->
                    <button type="button"
                            onclick="toggleFilters()"
                            class="flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 
               bg-white hover:bg-gray-50 text-sm font-medium 
               transition-all shadow-sm">
                        <!-- Icono embudo (Heroicons / SVG inline) -->
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-4 h-4 text-[#98cf54]"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L15 12.414V19a1 1 0 01-.553.894l-4 2A1 1 0 019 20v-7.586L3.293 6.707A1 1 0 013 6V4z" />
                        </svg>
                        Categorías
                    </button>
                    
                    <div id="filtersPanel"
                         class="mt-4 overflow-hidden transition-all duration-300
            max-h-0 opacity-0 scale-95 pointer-events-none">

                        <div class="space-y-2 mb-4 p-4 rounded-2xl 
                border border-gray-200 bg-white shadow-sm">
                            <h4 class="font-bold text-sm">Categorías</h4>

                            <div class="space-y-2">
                                <label class="flex items-center gap-3 cursor-pointer group">
                                    <input type="radio"
                                           name="categoryId"
                                           value=""
                                           checked="@(!Model.CategoryId.HasValue)"
                                           class="border-gray-300 text-[#98cf54] focus:ring-[#98cf54] h-4 w-4"
                                           onchange="this.form.submit()" />
                                    <span class="text-sm font-medium group-hover:text-[#98cf54] transition-colors">
                                        Todas las categorías
                                    </span>
                                </label>

                                @if (Model.AvailableCategories != null)
                                {
                                    @foreach (var category in Model.AvailableCategories)
                                    {
                                        <label class="flex items-center gap-3 cursor-pointer group">
                                            <input type="radio"
                                                   name="categoryId"
                                                   value="@category.Id"
                                                   checked="@(Model.CategoryId == category.Id)"
                                                   class="border-gray-300 text-[#98cf54] focus:ring-[#98cf54] h-4 w-4"
                                                   onchange="this.form.submit()" />
                                            <span class="text-sm font-medium group-hover:text-[#98cf54] transition-colors">
                                                @category.Name
                                            </span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                    
                                        <!-- Status -->
                    <button type="button"
                            onclick="toggleStatusFilters()"
                            class="flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 
               bg-white hover:bg-gray-50 text-sm font-medium 
               transition-all shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="w-4 h-4 text-[#98cf54]"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L15 12.414V19a1 1 0 01-.553.894l-4 2A1 1 0 019 20v-7.586L3.293 6.707A1 1 0 013 6V4z" />
                        </svg>
                        Estado
                    </button>
<div id="statusFiltersPanel"
     class="mt-4 overflow-hidden transition-all duration-300
            max-h-0 opacity-0 scale-95 pointer-events-none">

    <div class="space-y-4 mb-4 p-4 rounded-2xl 
                border border-gray-200 bg-white shadow-sm">
        <h4 class="font-bold text-sm">Estado del Producto</h4>

        <div class="space-y-3">
            <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio"
                       name="status"
                       value=""
                       checked="@(!Model.Status.HasValue)"
                       class="border-gray-300 text-[#98cf54] focus:ring-[#98cf54] h-4 w-4"
                       onchange="this.form.submit()" />
                <span class="text-sm font-medium group-hover:text-[#98cf54] transition-colors">
                    Todos
                </span>
            </label>

            <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio"
                       name="status"
                       value="0"
                       checked="@(Model.Status == flea_WebProj.Models.Enums.ProductStatus.Available)"
                       class="border-gray-300 text-[#98cf54] focus:ring-[#98cf54] h-4 w-4"
                       onchange="this.form.submit()" />
                <span class="text-sm font-medium group-hover:text-[#98cf54] transition-colors">
                    Disponible
                </span>
            </label>

            <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio"
                       name="status"
                       value="1"
                       checked="@(Model.Status == flea_WebProj.Models.Enums.ProductStatus.Sold)"
                       class="border-gray-300 text-[#98cf54] focus:ring-[#98cf54] h-4 w-4"
                       onchange="this.form.submit()" />
                <span class="text-sm font-medium group-hover:text-[#98cf54] transition-colors">
                    Vendido
                </span>
            </label>
        </div>
    </div>
</div></div>

                    <!-- Price Range -->
                    <div class="space-y-4 mb-4">
                        <h4 class="font-bold text-sm">Rango de Precio</h4>
                        <div class="flex items-center gap-3">
                            <div class="relative flex-1">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs">$</span>
                                <input type="number" 
                                       name="minPrice" 
                                       value="@Model.MinPrice"
                                       class="w-full pl-7 pr-3 py-2 text-sm bg-white border-none ring-1 ring-gray-200 rounded-lg focus:ring-2 focus:ring-[#98cf54] outline-none" 
                                       placeholder="Min"
                                       step="0.01"/>
                            </div>
                            <span class="text-gray-400">—</span>
                            <div class="relative flex-1">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs">$</span>
                                <input type="number" 
                                       name="maxPrice" 
                                       value="@Model.MaxPrice"
                                       class="w-full pl-7 pr-3 py-2 text-sm bg-white border-none ring-1 ring-gray-200 rounded-lg focus:ring-2 focus:ring-[#98cf54] outline-none" 
                                       placeholder="Max"
                                       step="0.01"/>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </aside>

        <!-- Main Content (75%) -->
        <section class="flex-1">
            <!-- Results Header -->
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h1 class="text-2xl font-extrabold mb-1">
                        @if (Model.TotalResults > 0)
                        {
                            <text>Explorar Productos</text>
                        }
                        else
                        {
                            <text>Productos Recientes</text>
                        }
                    </h1>
                </div>
            </div>

            @if (!Model.Results.Any())
            {
                <!-- Empty State -->
                <div class="text-center py-20">
                    <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gray-100 flex items-center justify-center">
                        <span class="material-symbols-outlined text-gray-400 text-5xl">inventory_2</span>
                    </div>
                    <h4 class="text-2xl font-bold text-[#25231e] mb-2">No se encontraron productos</h4>
                    <p class="text-gray-500 mb-8 max-w-md mx-auto">
                        Intenta con otros filtros o crea una nueva publicación
                    </p>
                    @if (isAuth)
                    {
                        <a asp-controller="Posts" asp-action="Create" 
                           class="inline-flex items-center gap-2 bg-[#98cf54] hover:bg-[#88bf44] text-white px-6 py-3 rounded-xl font-bold transition-all">
                            <span class="material-symbols-outlined">add_circle</span>
                            Crear Publicación
                        </a>
                    }
                </div>
            }
            else
            {
                <!-- Results Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                    @foreach (var post in Model.Results)
                    {
                        <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.PostId"
                           class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col">
                            <!-- Image -->
                            <div class="relative aspect-[4/5] overflow-hidden">
                                <img src="@post.MainImage" 
                                     alt="@post.Title" 
                                     class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"/>
                                <div class="absolute top-4 left-4">
                                    <span class="@(post.Status == flea_WebProj.Models.Enums.ProductStatus.Available ? "bg-[#98cf54]" : "bg-[#25231e]") text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
                                        @post.StatusText
                                    </span>
                                </div>
                            </div>

                            <!-- Content -->
                            <div class="p-5 flex-1 flex flex-col">
                                <div class="flex justify-between items-start mb-2">
                                    <h3 class="font-bold text-lg text-[#25231e] leading-tight line-clamp-1">@post.Title</h3>
                                    <span class="font-extrabold text-lg text-[#25231e] ml-2 flex-shrink-0">$@post.Price.ToString("N2")</span>
                                </div>
                                <p class="text-sm text-gray-500 line-clamp-2 mb-4">
                                    @post.Description
                                </p>
                                <div class="flex items-center gap-2 mt-auto pt-4 border-t border-gray-100">
                                    <img src="@post.AuthorProfilePic" 
                                         alt="@post.AuthorUsername" 
                                         class="w-6 h-6 rounded-full object-cover"/>
                                    <span class="text-xs font-semibold text-gray-500">@@@post.AuthorUsername</span>
                                    <span class="text-[10px] text-gray-400 ml-auto">@post.CreatedAt.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                        </a>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="mt-16 flex items-center justify-center gap-2">
                        <!-- Previous -->
                        @if (Model.Page > 1)
                        {
                            <a asp-action="Index" 
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-minPrice="@Model.MinPrice"
                               asp-route-maxPrice="@Model.MaxPrice"
                               asp-route-status="@Model.Status"
                               asp-route-page="@(Model.Page - 1)"
                               class="w-10 h-10 rounded-xl flex items-center justify-center hover:bg-white transition-colors text-gray-400">
                                <span class="material-symbols-outlined">chevron_left</span>
                            </a>
                        }
                        else
                        {
                            <button disabled class="w-10 h-10 rounded-xl flex items-center justify-center text-gray-300 cursor-not-allowed">
                                <span class="material-symbols-outlined">chevron_left</span>
                            </button>
                        }

                        <!-- Pages -->
                        @for (var i = 1; i <= Model.TotalPages; i++)
                        {
                            var pageNum = i;
                            @if (pageNum == Model.Page)
                            {
                                <button class="w-10 h-10 rounded-xl flex items-center justify-center bg-[#98cf54] text-white font-bold shadow-lg shadow-[#98cf54]/30">
                                    @pageNum
                                </button>
                            }
                            else if (pageNum == 1 || pageNum == Model.TotalPages || (pageNum >= Model.Page - 1 && pageNum <= Model.Page + 1))
                            {
                                <a asp-action="Index" 
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-minPrice="@Model.MinPrice"
                                   asp-route-maxPrice="@Model.MaxPrice"
                                   asp-route-status="@Model.Status"
                                   asp-route-page="@pageNum"
                                   class="w-10 h-10 rounded-xl flex items-center justify-center hover:bg-white transition-colors font-bold">
                                    @pageNum
                                </a>
                            }
                            else if (pageNum == Model.Page - 2 || pageNum == Model.Page + 2)
                            {
                                <span class="px-2 text-gray-400">...</span>
                            }
                        }

                        <!-- Next -->
                        @if (Model.Page < Model.TotalPages)
                        {
                            <a asp-action="Index" 
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-minPrice="@Model.MinPrice"
                               asp-route-maxPrice="@Model.MaxPrice"
                               asp-route-status="@Model.Status"
                               asp-route-page="@(Model.Page + 1)"
                               class="w-10 h-10 rounded-xl flex items-center justify-center hover:bg-white transition-colors text-gray-400">
                                <span class="material-symbols-outlined">chevron_right</span>
                            </a>
                        }
                        else
                        {
                            <button disabled class="w-10 h-10 rounded-xl flex items-center justify-center text-gray-300 cursor-not-allowed">
                                <span class="material-symbols-outlined">chevron_right</span>
                            </button>
                        }
                    </div>
                }
            }
        </section>
    </div>
</main>

<style>
    /* Custom scrollbar */
    ::-webkit-scrollbar {
        width: 6px;
    }
    ::-webkit-scrollbar-track {
        background: transparent;
    }
    ::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 10px;
    }
</style>

<script>
    function toggleFilters() {
        const panel = document.getElementById('filtersPanel');
        const isOpen = panel.classList.contains('max-h-[500px]');

        panel.classList.toggle('max-h-0', isOpen);
        panel.classList.toggle('opacity-0', isOpen);
        panel.classList.toggle('scale-95', isOpen);
        panel.classList.toggle('pointer-events-none', isOpen);

        panel.classList.toggle('max-h-[500px]', !isOpen);
        panel.classList.toggle('opacity-100', !isOpen);
        panel.classList.toggle('scale-100', !isOpen);
        panel.classList.toggle('pointer-events-auto', !isOpen);
    }

        function toggleStatusFilters() {
        const panel = document.getElementById('statusFiltersPanel');
        const isOpen = panel.classList.contains('max-h-[400px]');

        panel.classList.toggle('max-h-0', isOpen);
        panel.classList.toggle('opacity-0', isOpen);
        panel.classList.toggle('scale-95', isOpen);
        panel.classList.toggle('pointer-events-none', isOpen);

        panel.classList.toggle('max-h-[400px]', !isOpen);
        panel.classList.toggle('opacity-100', !isOpen);
        panel.classList.toggle('scale-100', !isOpen);
        panel.classList.toggle('pointer-events-auto', !isOpen);
    }

</script>
